# ---------------------------------------------------------------------------
# .env.example
# Purpose: Template for local environment configuration. Copy this file to
# ".env" and fill in real values. Never commit the actual ".env" file.
# ---------------------------------------------------------------------------

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=taxi_rides

# Spark
SPARK_MASTER=local[*]
SPARK_APP_NAME=UberThinking

# Windows only: path to a folder containing bin/winutils.exe + bin/hadoop.dll
# (needed because Spark's bundled Hadoop libs expect these on Windows).
# Leave empty on macOS/Linux. See README.md "Windows setup notes".
# HADOOP_HOME=C:\hadoop

# File paths
RAW_DATA_PATH=data/raw/taxi_data.parquet
ZONE_LOOKUP_PATH=data/zone_lookup/taxi_zone_lookup.csv
CHECKPOINT_PATH=output/checkpoints/
PARQUET_OUTPUT_PATH=output/parquet/
MODEL_PATH=models/fare_prediction

# Producer behavior
PRODUCER_DELAY_SECONDS=0.5
