# Copy this file to ".env" and adjust if needed. All values have sensible
# defaults, so .env is optional on macOS/Linux.

# Windows only: folder containing bin/winutils.exe + bin/hadoop.dll.
# Leave empty on macOS/Linux. See README "Windows setup".
# HADOOP_HOME=C:\hadoop

# Java 11 or 17 for Spark (Spark 3.5 does not support Java 8).
# JAVA_HOME=C:\Program Files\Java\jdk-17

# File paths
HISTORICAL_DATA_PATH=data/raw
ZONE_LOOKUP_PATH=data/zone_lookup/taxi_zone_lookup.csv
STREAM_INPUT_PATH=data/stream
RIDES_OUTPUT_PATH=output/rides
CHECKPOINT_PATH=output/checkpoint
MODEL_PATH=models/fare_model

# How the fake live feed behaves
STREAM_DELAY_SECONDS=5
STREAM_BATCH_SIZE=50
